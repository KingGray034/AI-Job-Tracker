{
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsserver.useSyntaxServer": "never",
  "js/ts.tsserver.log": "off",
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": ["**/node_modules", "**/.pnpm", "**/.next"]
  },
  "js/ts.validate.enabled": true,
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.pnpm/**": true,
    "**/.next/**": true
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "css.lint.unknownAtRules": "ignore",
  "css.validate": false,
  "scss.validate": false
}
